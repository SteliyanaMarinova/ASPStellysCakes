@model IEnumerable<ASPStellysCake.Models.Order>

@{
    ViewData["Title"] = "Index";
}

<h1>Поръчки</h1>

<p>
    <a asp-action="Create">Създай нова поръчка</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                Клиент
            </th>
            <th>
                Продукт
            </th>
            <th>
                Брой
            </th>
            <th>
                Дата на създаване
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Customers.UserName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Products.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Quantity)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.RegisterOn)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Редактиране</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Детайли</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Изтриване</a>
            </td>
        </tr>
}
    </tbody>
</table>
