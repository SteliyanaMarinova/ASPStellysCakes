@model ASPStellysCake.Models.Order

@{
    ViewData["Title"] = "Delete";
}

<h1>Изтриване</h1>

<h3>Сигурен ли си, че искаш да изтриеш тази поръчка?</h3>
<div>
    <h4>Order</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            Клиент
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Customers.UserName)
        </dd>
        <dt class = "col-sm-2">
            Продукт
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Products.Name)
        </dd>
        <dt class = "col-sm-2">
            Брой
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Quantity)
        </dd>
        <dt class = "col-sm-2">
            Дата на създаване
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.RegisterOn)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Изтрий" class="btn btn-danger" /> |
        <a asp-action="Index">Върни се в списъка</a>
    </form>
</div>
